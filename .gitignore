# ============================================================
# ホワイトリスト方式 — TimeTracker関連ファイル + Teams週報自動生成ツールのみ追跡
# ============================================================

# まずすべて無視
*

# このファイル自身
!.gitignore

# TimeTrackerNX 登録ツール本体
!README.md
!requirements.txt
!timetracker_register.py
!timetracker_config.json
!tt.ps1
!timetracker_manual.html

# 進捗管理 Excel → Outlook スケジューラ
!schedule_tasks.py
!st.ps1

# 日報自動生成
!tools/
tools/*
!tools/nippo/
tools/nippo/*
!tools/nippo/outlook_auto_nippo.py
!tools/nippo/outlook_auto_nippo_tz.py
!tools/nippo/convert_nippo_to_utf8.py

# Teams チャット週報自動生成ツール(個人情報なしで第三者配布可能。
# tools/.user_config.json / tools/.gh_models_token / tools/.msal_token_cache.json / tools/.teams_allow は
# 上記 tools/* により引き続きgit管理対象外（個人設定・認証情報なので意図的）)
!wr.ps1
!tools/teams_weekly_report.py
!tools/.user_config.example.json

# VS Code ターミナルプロファイル定義
!.vscode/
.vscode/*
!.vscode/settings.json

# output/ サブフォルダの中の削除ユーティリティのみ
!output/
output/*
!output/tt_delete_date.py

# APIキーは絶対に追跡しない
tt_apikey.txt
