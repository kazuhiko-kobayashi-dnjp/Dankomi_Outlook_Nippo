# ============================================================
# ホワイトリスト方式 — TimeTracker関連ファイル + Teams週報自動生成ツールのみ追跡
# ============================================================

# まずすべて無視
*

# このファイル自身
!.gitignore

# TimeTrackerNX 登録ツール本体
!README.md
!requirements.txt
!timetracker_register.py
!timetracker_config.json
!tt.ps1
!timetracker_manual.html

# 進捗管理 Excel → Outlook スケジューラ
!schedule_tasks.py
!st.ps1

# 日報自動生成
!tools/
tools/*
!tools/nippo/
tools/nippo/*
!tools/nippo/outlook_auto_nippo.py
!tools/nippo/outlook_auto_nippo_tz.py
!tools/nippo/convert_nippo_to_utf8.py

# Teams チャット週報自動生成ツール(個人情報なしで第三者配布可能。
# tools/.user_config.json / tools/.gh_models_token / tools/.msal_token_cache.json / tools/.teams_allow は
# 上記 tools/* により引き続きgit管理対象外（個人設定・認証情報なので意図的）)
!wr.ps1
!tools/teams_weekly_report.py
!tools/.user_config.example.json

# VS Code ターミナルプロファイル定義
!.vscode/
.vscode/*
!.vscode/settings.json

# 露出制御業務進捗管理 (Webアプリ) — アプリコードのみ追跡。
# app/data/ (業務データ本体・ローカルバックアップ・元Excelパス設定) と
# app/.msal_token_cache.json (SharePoint認証キャッシュ) は個人情報/認証情報のため対象外。
!manage_exp_progress/
manage_exp_progress/*
!manage_exp_progress/README.md
!manage_exp_progress/CLAUDE.md
!manage_exp_progress/requirements.txt
!manage_exp_progress/app/
manage_exp_progress/app/*
!manage_exp_progress/app/server.py
!manage_exp_progress/app/import_excel.py
!manage_exp_progress/app/export_excel.py
!manage_exp_progress/app/richtext_bridge.py
!manage_exp_progress/app/sharepoint_backup.py
!manage_exp_progress/app/public/
!manage_exp_progress/app/public/**

# output/ サブフォルダの中の削除ユーティリティのみ
!output/
output/*
!output/tt_delete_date.py

# Teams会議録画 -> transcript(VTT)取得 / DR勧告表用JSON生成 (Power Automate連携向け)
!auto_summarize_recordings.py
!auto_summarize_recordings_v3.py

# APIキーは絶対に追跡しない
tt_apikey.txt
